---
interface Props {
  number: number;
  title: string;
  thumbnail: string;
  description: string;
  spotifyUrl: string;
  defaultExpanded?: boolean;
}

const { number, title, thumbnail, description, spotifyUrl, defaultExpanded = false } = Astro.props;

// Convert title to Title Case
const titleCase = title
  .toLowerCase()
  .split(" ")
  .map((word) => {
    const small = ["a", "an", "the", "and", "but", "or", "for", "nor", "on", "at", "to", "by", "in", "of", "up"];
    return small.includes(word) ? word : word.charAt(0).toUpperCase() + word.slice(1);
  })
  .join(" ");
const formattedTitle = titleCase.charAt(0).toUpperCase() + titleCase.slice(1);
---

<div class="episode-row" data-expanded={defaultExpanded ? "true" : "false"}>
  <button
    class="episode-toggle w-full text-left cursor-pointer"
    aria-expanded={defaultExpanded ? "true" : "false"}
  >
    <!-- Desktop layout: 3-column grid -->
    <div class="hidden md:grid md:grid-cols-[1fr_180px_1fr] gap-8 items-stretch">
      <!-- Left: Number + Title + Spotify button -->
      <div class="flex flex-col gap-1 py-6">
        <span class="text-white/60 font-bold text-xs uppercase tracking-widest">Episode {number}</span>
        <h4 class:list={["font-normal text-white text-base md:text-lg mt-1 episode-title", defaultExpanded ? "episode-title-expanded" : "episode-title-collapsed"]}>
          {formattedTitle}
        </h4>
        <!-- Spotify button: shown only when expanded -->
        <div class:list={["episode-listen-btn mt-4", !defaultExpanded && "hidden"]}>
          <a
            href={spotifyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-white/10 text-white font-bold text-xs uppercase tracking-wider px-5 py-2.5 rounded-full border border-white/20 hover:bg-white/20 transition-colors"
            onclick="event.stopPropagation();"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
            </svg>
            Listen on Spotify
          </a>
        </div>
      </div>

      <!-- Center: Image pinned to bottom of cell, peek from top -->
      <div class="flex flex-col justify-end">
        <div class="relative overflow-hidden episode-image-wrapper rounded-t-lg" style={`height: ${defaultExpanded ? '180px' : '60px'}; transition: height 0.5s cubic-bezier(0.4, 0, 0.2, 1);`}>
          <img
            src={thumbnail}
            alt={formattedTitle}
            class="w-full aspect-square object-cover object-top border border-white rounded-t-lg"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Right: Description -->
      <div class="py-6">
        <p class:list={["text-text-light text-sm leading-relaxed episode-desc", defaultExpanded ? "episode-desc-expanded" : "episode-desc-collapsed"]}>
          {description}
        </p>
      </div>
    </div>

    <!-- Mobile layout: stacked -->
    <div class="md:hidden py-6">
      <div class="flex flex-col gap-1">
        <span class="text-white/60 font-bold text-xs uppercase tracking-widest">Episode {number}</span>
        <h4 class="font-normal text-white text-base mt-1 episode-title">
          {formattedTitle}
        </h4>
      </div>
      <!-- Mobile image: shown only when expanded -->
      <div class:list={["episode-mobile-image mt-4", !defaultExpanded && "hidden"]}>
        <img
          src={thumbnail}
          alt={formattedTitle}
          class="w-full rounded-lg border border-white"
          loading="lazy"
        />
        <div class="mt-3">
          <a
            href={spotifyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-white/10 text-white font-bold text-xs uppercase tracking-wider px-5 py-2.5 rounded-full border border-white/20 hover:bg-white/20 transition-colors"
            onclick="event.stopPropagation();"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
            </svg>
            Listen on Spotify
          </a>
        </div>
      </div>
    </div>
  </button>
  <!-- Divider -->
  <hr class="border-white/10" />
</div>

<style>
  .episode-desc {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .episode-desc-collapsed {
    -webkit-line-clamp: 1;
  }
  .episode-desc-expanded {
    -webkit-line-clamp: 6;
  }
  .episode-title {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .episode-title-collapsed {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    overflow: hidden;
  }
  .episode-title-expanded {
    -webkit-line-clamp: unset;
    overflow: visible;
  }
  .episode-listen-btn {
    display: block !important;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1), max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }
  .episode-listen-btn.hidden {
    opacity: 0;
    max-height: 0 !important;
    margin-top: 0 !important;
  }
  .episode-listen-btn:not(.hidden) {
    opacity: 1;
    max-height: 60px;
  }
  .episode-mobile-image {
    display: block !important;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1), max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }
  .episode-mobile-image.hidden {
    opacity: 0;
    max-height: 0 !important;
    margin-top: 0 !important;
  }
  .episode-mobile-image:not(.hidden) {
    opacity: 1;
    max-height: 500px;
  }
</style>
