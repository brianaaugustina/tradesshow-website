---
import EpisodeRow from "./EpisodeRow.astro";
import { fetchEpisodes } from "../lib/rss";

const episodes = await fetchEpisodes(5);
---

<section class="bg-charcoal py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6 fade-in">
    <!-- Season header -->
    <div class="mb-12 md:text-center">
      <p class="text-red font-bold text-sm uppercase tracking-widest mb-3">Now Playing</p>
      <h2 class="font-extrabold text-2xl text-white mb-4">San Francisco</h2>
      <p class="text-text-light text-base md:text-lg max-w-3xl leading-relaxed md:mx-auto">
        Tech capital. Craft city. Season 2 goes on location in San Francisco — inside the workshops of the artisans making things by hand in the most automated city on earth.
      </p>
    </div>

    <!-- Divider -->
    <hr class="border-white/10 mb-0" />

    <!-- Episode list -->
    <div class="mb-12">
      {episodes.length > 0 ? (
        episodes.map((ep, i) => (
          <EpisodeRow
            number={ep.number}
            title={ep.title}
            thumbnail={ep.thumbnail}
            description={ep.description}
            spotifyUrl={ep.spotifyUrl}
            defaultExpanded={i === 0}
          />
        ))
      ) : (
        <p class="text-text-light text-center py-8">Episodes loading soon...</p>
      )}
    </div>

    <!-- Episode expand/collapse script -->
    <script>
      document.querySelectorAll(".episode-toggle").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          // Don't toggle if clicking a link
          if ((e.target as HTMLElement).closest("a")) return;

          const row = btn.closest(".episode-row") as HTMLElement;
          if (!row) return;
          const isExpanded = row.dataset.expanded === "true";

          // Desktop elements
          const imageWrapper = row.querySelector(".episode-image-wrapper") as HTMLElement;
          const desc = row.querySelector(".episode-desc") as HTMLElement;
          const titleEl = row.querySelector(".episode-title") as HTMLElement;
          const listenBtn = row.querySelector(".episode-listen-btn") as HTMLElement;

          // Mobile elements
          const mobileImage = row.querySelector(".episode-mobile-image") as HTMLElement;

          if (isExpanded) {
            // Collapse
            row.dataset.expanded = "false";
            btn.setAttribute("aria-expanded", "false");
            if (imageWrapper) imageWrapper.style.height = "60px";
            if (titleEl) {
              titleEl.classList.remove("episode-title-expanded");
              titleEl.classList.add("episode-title-collapsed");
            }
            if (desc) {
              desc.classList.remove("episode-desc-expanded");
              desc.classList.add("episode-desc-collapsed");
            }
            if (listenBtn) listenBtn.classList.add("hidden");
            if (mobileImage) mobileImage.classList.add("hidden");
          } else {
            // Expand
            row.dataset.expanded = "true";
            btn.setAttribute("aria-expanded", "true");
            if (imageWrapper) imageWrapper.style.height = "180px";
            if (titleEl) {
              titleEl.classList.remove("episode-title-collapsed");
              titleEl.classList.add("episode-title-expanded");
            }
            if (desc) {
              desc.classList.remove("episode-desc-collapsed");
              desc.classList.add("episode-desc-expanded");
            }
            if (listenBtn) listenBtn.classList.remove("hidden");
            if (mobileImage) mobileImage.classList.remove("hidden");
          }
        });
      });
    </script>

    <!-- Platform buttons -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center sm:justify-center gap-4">
      <a
        href="https://podcasts.apple.com/us/podcast/the-trades-show/id1821328343"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-black text-white font-bold text-xs uppercase tracking-wider px-6 py-3 rounded-full border border-white/20 hover:bg-white/10 transition-colors"
      >
        <svg class="w-5 h-5" viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="ap-grad" x1="25" y1="50" x2="25" y2="0" gradientUnits="userSpaceOnUse">
              <stop offset="0" stop-color="#822CBE"/>
              <stop offset="1" stop-color="#D56DFB"/>
            </linearGradient>
          </defs>
          <rect width="50" height="50" rx="11" fill="url(#ap-grad)"/>
          <g fill="none" stroke="white" stroke-width="2" stroke-linecap="round">
            <path d="M15.5 30.5a12 12 0 1 1 19 0"/>
            <path d="M18.5 28.5a8.5 8.5 0 1 1 13 0"/>
          </g>
          <circle cx="25" cy="25" r="2.5" fill="white"/>
          <path d="M22.5 33c-.3 2.5-.8 5.5-1 6.5-.2 1.2.8 2 1.8 2h3.4c1 0 2-.8 1.8-2-.2-1-.7-4-1-6.5a1.5 1.5 0 0 0-1.5-1.3h-2a1.5 1.5 0 0 0-1.5 1.3z" fill="white"/>
        </svg>
        Apple Podcasts
      </a>
      <a
        href="https://open.spotify.com/show/0g5nz0QQY4lNTi7qhfjBoj"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-black text-white font-bold text-xs uppercase tracking-wider px-6 py-3 rounded-full border border-white/20 hover:bg-white/10 transition-colors"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path fill="#1DB954" d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
        </svg>
        Watch or Listen on Spotify
      </a>
      <a
        href="https://www.youtube.com/@tradesshow"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-black text-white font-bold text-xs uppercase tracking-wider px-6 py-3 rounded-full border border-white/20 hover:bg-white/10 transition-colors"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path fill="#FF0000" d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
          <path fill="white" d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        Watch on YouTube
      </a>
    </div>
  </div>
</section>
