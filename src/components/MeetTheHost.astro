---

<section class="bg-cream pt-10 md:pt-14 pb-20 md:pb-28">
  <div class="max-w-6xl mx-auto px-6 fade-in">
    <div class="bg-card-beige rounded-3xl overflow-hidden">
      <div class="flex flex-col-reverse md:grid md:grid-cols-2 md:gap-0">
        <!-- Left: Bio -->
        <div class="p-8 md:p-14 flex flex-col justify-center">
          <p class="text-red font-bold text-sm uppercase tracking-widest mb-3">Meet the Host</p>
          <h2 class="font-extrabold text-2xl mb-6">Briana Ottoboni</h2>
          <div class="space-y-4 text-black/80 text-base leading-relaxed">
            <p>
              Briana Ottoboni is the host and creator of The Trades Show. After being awe-inspired by the work of a local cobbler who transformed a pair of old loafers, she apprenticed with a shoe cobbler and developed a fascination for the artisan trades – and a determination to revive them to their original glory, just like the cobbler did to her shoes.
            </p>
            <p>
              The Trades Show was born as a storytelling medium to highlight artisan pathways in a return to what it means to be human.
            </p>
            <p>
              She is also the founder of The Corral, a national jobs board connecting artisans with work, building an artisan ecosystem purpose-built for a cultural moment that won't wait.
            </p>
          </div>

          <!-- Social icons -->
          <div class="flex items-center gap-4 mt-8">
            <a
              href="https://www.instagram.com/brianaaugustina"
              target="_blank"
              rel="noopener noreferrer"
              class="text-black/60 hover:text-black transition-colors"
              aria-label="Instagram"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
            <a
              href="https://www.linkedin.com/in/brianaottoboni/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-black/60 hover:text-black transition-colors"
              aria-label="LinkedIn"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            <a
              href="https://www.brianaaugustina.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-black/60 hover:text-black transition-colors"
              aria-label="Personal website"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Right: Headshot -->
        <div class="relative min-h-[400px] md:min-h-0">
          <img
            src="/images/briana-headshot.png"
            alt="Briana Ottoboni, host of The Trades Show"
            class="absolute inset-0 w-full h-full object-cover object-top grayscale"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
