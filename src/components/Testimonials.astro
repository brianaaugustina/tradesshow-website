---
import testimonials from "../data/testimonials.json";
---

<section class="bg-cream pt-20 md:pt-28 pb-10 md:pb-14 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6 fade-in">
    <h2 class="font-extrabold text-2xl text-left md:text-center mb-16">
      What people are saying
    </h2>

    <!-- Desktop: scrollable row for 5 cards -->
    <div class="hidden lg:block overflow-x-auto scrollbar-hide -mr-6">
      <div class="flex gap-6 pr-6" style="min-width: max-content;">
        {testimonials.map((t) => (
          <div class="flex-shrink-0 w-[280px] bg-card-beige rounded-2xl p-8 flex flex-col items-center text-center">
            <div class="flex gap-1 mb-6">
              {Array.from({ length: 5 }).map(() => (
                <svg class="w-5 h-5 text-red" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-sm leading-relaxed text-black/80">"{t.quote}"</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile/Tablet: horizontal swipeable carousel -->
    <div class="lg:hidden overflow-x-auto scrollbar-hide -mr-6">
      <div class="flex gap-4 pr-6" style="min-width: max-content;">
        {testimonials.map((t) => (
          <div class="flex-shrink-0 w-[280px] bg-card-beige rounded-2xl p-8 flex flex-col items-center text-center">
            <div class="flex gap-1 mb-6">
              {Array.from({ length: 5 }).map(() => (
                <svg class="w-5 h-5 text-red" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-sm leading-relaxed text-black/80">"{t.quote}"</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
